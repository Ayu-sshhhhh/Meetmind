# Copy this file to ".env" and replace only the values you plan to use.

# Optional cloud analysis / transcription
OPENAI_API_KEY=your_openai_api_key_here
MEETMIND_ANALYSIS_MODEL=gpt-4o-mini
MEETMIND_OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
MEETMIND_OPENAI_TIMEOUT_MS=120000

# Legacy alias still supported for older OpenAI transcription models
MEETMIND_TRANSCRIPTION_MODEL=whisper-1

# Transcription routing
# auto   = OpenAI first when configured, then local fallback
# openai = OpenAI first, then local fallback
# local  = Local first, then OpenAI fallback
MEETMIND_MEDIA_PROCESSING_MODE=auto
MEETMIND_LOCAL_ONLY_MEDIA_PROCESSING=false

# Local transcription stack
MEETMIND_LOCAL_TRANSCRIPTION=true
MEETMIND_LOCAL_WHISPER_MODEL=base
MEETMIND_PYTHON_BIN=python

# Optional local speaker diarization
MEETMIND_LOCAL_DIARIZATION=true
MEETMIND_LOCAL_DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Deployment tip:
# If you deploy MeetMind to a host without the Python whisper stack,
# set MEETMIND_LOCAL_TRANSCRIPTION=false and rely on OPENAI_API_KEY.
